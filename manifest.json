{
  "manifest_version": 3,
  "name": "Trump Truth Social Alert",
  "version": "1.3.0",
  "description": "Get instant browser notifications when President Trump posts on Truth Social.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://truthsocial.com/*",
    "https://trump-truth-server-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
